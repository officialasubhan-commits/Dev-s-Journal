// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  // extensions = [vector]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?   @map("profilePicture")
  biography     String?   @db.Text
  role          String    @default("USER") // "GUEST", "USER", "ADMIN"

  // Profile Extended
  displayName       String?
  shortIntroduction String?  @db.Text
  country           String?
  state             String?
  city              String?
  languages         String[]
  technologies      String[]
  spokenLanguages   String[]
  occupation        String?
  company           String?
  college           String?
  course            String?
  skills            String[]
  interests         String[]
  customStats       Json?

  website          String?
  githubProfile    String?
  linkedinProfile  String?
  twitterProfile   String?
  instagramProfile String?

  websiteThemePreference String  @default("system")
  profileCompleted       Boolean @default(false)

  // Security
  lastLogin           DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts      Account[]
  sessions      Session[]
  resetTokens   PasswordResetToken[]
  notifications Notification[]

  posts            Post[]
  projects         Project[]
  galleryImages    GalleryImage[]
  albums           Album[]
  userLearnings    UserLearning[]
  courses          Course[]
  books            Book[]
  certifications   Certification[]
  activities       Activity[]
  userAchievements UserAchievement[]
  comments         Comment[]
  detailedSkills   Skill[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Post {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  content        String    @db.Text // Rich text or markdown
  coverImage     String?
  published      Boolean   @default(false)
  readingTime    Int       @default(5)
  mood           String?
  tags           String[]
  likes          Int       @default(0)
  scheduledFor   DateTime?
  pinned         Boolean   @default(false)
  archived       Boolean   @default(false)
  seoTitle       String?
  seoDescription String?

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  comments Comment[]

  draftId String? @unique
  draft   Draft?  @relation(fields: [draftId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[]
}

model Comment {
  id          String  @id @default(cuid())
  authorName  String
  authorEmail String?
  content     String  @db.Text
  approved    Boolean @default(false) // For moderation

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id])

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Project {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  description    String   @db.Text
  content        String?  @db.Text
  features       String?  @db.Text
  challenges     String?  @db.Text
  lessonsLearned String?  @db.Text
  technologies   String[]
  githubUrl      String?
  liveUrl        String?
  coverImage     String?
  images         String[] // Screenshots gallery

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id])

  startDate DateTime?
  endDate   DateTime?
  published Boolean   @default(true)
  pinned    Boolean   @default(false)
  demoVideo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id          String  @id @default(cuid())
  name        String
  category    String // e.g., "Frontend", "Backend", "Tools"
  proficiency Int // 0 - 100
  icon        String? // SVG or classname

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  // Make skill name unique per user if userId is set, otherwise global
  // prisma does not support conditional unique constraints easily, so we remove the pure @unique
}

model UserLearning {
  id          String    @id @default(cuid())
  title       String
  platform    String
  progress    Int       @default(0) // 0 - 100
  status      String    @default("IN_PROGRESS") // "IN_PROGRESS", "COMPLETED"
  completedAt DateTime?
  
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  
  createdAt   DateTime  @default(now())
}

model Course {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  instructor       String
  instructorBio    String?  @db.Text
  instructorAvatar String?
  shortDescription String   @db.Text
  description      String   @db.Text
  coverImage       String?
  trailerUrl       String?
  difficulty       String   @default("Beginner") // Beginner, Intermediate, Advanced
  category         String
  tags             String[]
  duration         String
  lessonsCount     Int      @default(0)
  rating           Float    @default(0.0)
  studentsCount    Int      @default(0)
  language         String   @default("English")
  lastUpdated      DateTime @default(now())
  isFree           Boolean  @default(false)
  price            Float    @default(0.0)
  discountPrice    Float?
  outcomes         String[]
  requirements     String[]
  targetAudience   String[]
  certificateInfo  String?
  
  authorId         String?
  author           User?    @relation(fields: [authorId], references: [id])
  
  curriculum       CourseSection[]
  reviews          Review[]
  faqs             FAQ[]
  
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CourseSection {
  id        String   @id @default(cuid())
  title     String
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Lesson {
  id        String        @id @default(cuid())
  title     String
  duration  String
  isPreview Boolean       @default(false)
  sectionId String
  section   CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  order     Int           @default(0)
  createdAt DateTime      @default(now())
}

model Review {
  id        String   @id @default(cuid())
  userName  String
  rating    Float
  comment   String   @db.Text
  date      DateTime @default(now())
  avatarUrl String?
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  global    Boolean  @default(false) // If true, it's a global platform FAQ, else course-specific
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String?
  content   String   @db.Text
  avatarUrl String?
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Book {
  id         String  @id @default(cuid())
  title      String
  author     String
  status     String  @default("READING") // "READING", "COMPLETED", "WANT_TO_READ"
  coverImage String?
  rating     Int? // 1 - 5
  review     String? @db.Text

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Certification {
  id     String   @id @default(cuid())
  title  String
  issuer String
  date   DateTime
  url    String?
  image  String?
  skills String[] @default([])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Achievement {
  id          String   @id @default(cuid())
  title       String   @unique
  description String   @db.Text
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@unique([userId, achievementId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // e.g. "REGISTERED", "COMPLETED_PROFILE", "PUBLISHED_JOURNAL", etc.
  details   String?  @db.Text
  createdAt DateTime @default(now())
}

model Album {
  id          String         @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  images      GalleryImage[]

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model GalleryImage {
  id       String  @id @default(cuid())
  url      String
  publicId String? // For Cloudinary
  caption  String?

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id])

  albumId String?
  album   Album?  @relation(fields: [albumId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Draft {
  id        String   @id @default(cuid())
  title     String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post?
}

model Notification {
  id      String  @id @default(cuid())
  type    String // "SYSTEM", "CONTRIBUTION", "COMMENT", "LIKE", "MODERATION"
  title   String?
  message String
  link    String?
  read    Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  published   Boolean   @default(true)
  priority    String    @default("MEDIUM")
  pinned      Boolean   @default(false)
  archived    Boolean   @default(false)
  publishedAt DateTime? @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// SiteSettings removed in favor of modular settings models.

model MaintenanceLog {
  id         String    @id @default(cuid())
  enabledAt  DateTime  @default(now())
  disabledAt DateTime?
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  country   String?
  device    String? // "desktop" | "mobile" | "tablet"
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model GeneralSettings {
  id                  String   @id @default("singleton")
  enableComments      Boolean  @default(true)
  enableGallery       Boolean  @default(true)
  enableLearning      Boolean  @default(true)
  enableNotifications Boolean  @default(true)
  googleAnalyticsId   String   @default("")
  maxUploadSizeMb     Int      @default(5)
  launchedAt          DateTime @default(now())
  authorName          String   @default("")
  authorEmail         String   @default("")
  updatedAt           DateTime @updatedAt
}

model MaintenanceSettings {
  id                   String   @id @default("singleton")
  maintenanceEnabled   Boolean  @default(false)
  maintenanceMessage   String   @default("We'll be back soon!")
  maintenanceUpdatedBy String?
  updatedAt            DateTime @updatedAt
}

model Backup {
  id          String   @id @default(cuid())
  name        String
  description String?
  notes       String?  @default("")
  createdAt   DateTime @default(now())
  size        Int
  status      String
  payload     String   @db.Text
  isAuto      Boolean  @default(false)
}

model BrandSettings {
  id              String   @id @default("singleton")
  siteTitle       String   @default("Boss Journal")
  siteTagline     String   @default("My personal portfolio, journal, and digital headquarters.")
  siteDescription String   @default("My personal portfolio, journal, and digital headquarters.")
  siteLogo        String   @default("")
  siteFavicon     String   @default("")
  siteUrl         String   @default("")
  defaultTheme    String   @default("light")
  defaultLanguage String   @default("en")
  brandColors     Json     @default("{\"primary\": \"#F97316\", \"accent\": \"#FB7185\"}")
  updatedAt       DateTime @updatedAt
}

model SeoSettings {
  id             String   @id @default("singleton")
  seoTitle       String   @default("Boss Journal | Portfolio & Digital Home")
  seoDescription String   @default("My digital home, where I document my journey, learning, projects, and daily life.")
  seoKeywords    String   @default("")
  ogImage        String   @default("")
  robots         String   @default("index, follow")
  canonicalUrl   String   @default("")
  twitterCards   String   @default("summary_large_image")
  structuredData Json     @default("{}")
  updatedAt      DateTime @updatedAt
}

model HomepageSettings {
  id                   String   @id @default("singleton")
  heroTitle            String   @default("Designing simple, warm & premium digital experiences.")
  heroHighlighted      String   @default("warm & premium")
  heroDescription      String   @default("I am a Software Engineer and UI/UX Designer. This is my digital space where I log my daily learnings, showcase craft projects, and write summaries.")
  heroProfileImage     String   @default("")
  heroBgDecor          String   @default("glow")
  heroBtnPrimaryText   String   @default("Explore Projects")
  heroBtnPrimaryLink   String   @default("/projects")
  heroBtnSecondaryText String   @default("Read Journal")
  heroBtnSecondaryLink String   @default("/journal")
  authorTitle          String   @default("Software Engineer & UI/UX Designer")
  authorBio            String   @default("Based in India. Focuses on Next.js 16, React 19, TypeScript, and modern clean interface details.")
  featuredProjects     String[] @default([])
  featuredPosts        String[] @default([])
  featuredCertificates String[] @default([])
  featuredCourses      String[] @default([])
  updatedAt            DateTime @updatedAt
}

model AboutSettings {
  id               String   @id @default("singleton")
  aboutTitle       String   @default("About Me")
  aboutDescription String   @default("")
  aboutImage       String   @default("")
  resumePdf        String   @default("")
  timeline         Json     @default("[]")
  updatedAt        DateTime @updatedAt
}

model ContactSettings {
  id                 String   @id @default("singleton")
  contactHeading     String   @default("Get In Touch")
  contactDescription String   @default("Have a project in mind, want to collaborate, or just want to say hi? Send me a message!")
  availabilityStatus String   @default("Available")
  contactEmail       String   @default("")
  phoneNumber        String   @default("")
  whatsappNumber     String   @default("")
  country            String   @default("")
  state              String   @default("")
  city               String   @default("")
  fullAddress        String   @default("")
  googleMapsUrl      String   @default("")
  githubUrl          String   @default("")
  linkedinUrl        String   @default("")
  twitterUrl         String   @default("")
  instagramUrl       String   @default("")
  facebookUrl        String   @default("")
  youtubeUrl         String   @default("")
  discordUsername    String   @default("")
  telegramUsername   String   @default("")
  updatedAt          DateTime @updatedAt
}

model CourseSettings {
  id                      String   @id @default("singleton")
  homepageFeaturedCourses String[] @default([])
  defaultInstructor       String   @default("")
  defaultCurrency         String   @default("USD")
  defaultLanguage         String   @default("English")
  updatedAt               DateTime @updatedAt
}

model CertificateSettings {
  id                           String   @id @default("singleton")
  homepageFeaturedCertificates String[] @default([])
  enableVerification           Boolean  @default(true)
  updatedAt                    DateTime @updatedAt
}

model NotificationSettings {
  id                  String   @id @default("singleton")
  welcomeNotification String   @default("Welcome to your Admin Dashboard!")
  announcementBanner  String   @default("")
  bannerEnabled       Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

model GallerySettings {
  id             String   @id @default("singleton")
  featuredImages String[] @default([])
  galleryBanner  String   @default("")
  updatedAt      DateTime @updatedAt
}

model FooterSettings {
  id          String   @id @default("singleton")
  copyright   String   @default("© All rights reserved.")
  footerLinks Json     @default("[]")
  footerLogo  String   @default("")
  updatedAt   DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String   @unique
  filename  String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())
}
